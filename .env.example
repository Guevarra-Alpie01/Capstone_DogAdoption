DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# Optional helper for PythonAnywhere host auto-add.
# Example: yourusername.pythonanywhere.com
PYTHONANYWHERE_DOMAIN=
DJANGO_CSRF_TRUSTED_ORIGINS=
DJANGO_USE_X_FORWARDED_HOST=True
DJANGO_SECURE_SSL_REDIRECT=False
DJANGO_SECURE_HSTS_SECONDS=0
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=False
DJANGO_SECURE_HSTS_PRELOAD=False
DJANGO_SECURE_REFERRER_POLICY=strict-origin-when-cross-origin
DJANGO_X_FRAME_OPTIONS=DENY
DJANGO_SESSION_COOKIE_SAMESITE=Lax
DJANGO_CSRF_COOKIE_SAMESITE=Lax
DJANGO_SECURE_CONTENT_TYPE_NOSNIFF=True
DJANGO_CSP_FRAME_ANCESTORS='none'

DB_ENGINE=django.db.backends.mysql
DB_NAME=dogadoption_database
DB_USER=root
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=3306
DB_CONN_MAX_AGE=60
DB_CONN_HEALTH_CHECKS=True
DB_CONNECT_TIMEOUT=10
DB_SQL_MODE=STRICT_TRANS_TABLES

CACHE_BACKEND=locmem
LOCMEM_CACHE_LOCATION=pet_adoption-local
REDIS_URL=redis://127.0.0.1:6379/1
REDIS_CACHE_TIMEOUT=300
REDIS_CACHE_KEY_PREFIX=pet_adoption
DJANGO_LOG_LEVEL=INFO
RATE_LIMIT_ENABLED=True
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_DEFAULT_REQUESTS=60
RATE_LIMIT_AUTH_REQUESTS=10
RATE_LIMIT_INTERACTION_REQUESTS=30
RATE_LIMIT_SUBMISSION_REQUESTS=12

CREATE_DEFAULT_ADMIN=False
DEFAULT_ADMIN_USERNAME=
DEFAULT_ADMIN_EMAIL=
DEFAULT_ADMIN_PASSWORD=
