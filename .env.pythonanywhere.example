# PythonAnywhere deployment template.
# Copy this to `.env` on PythonAnywhere and fill in the placeholders.
DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=bayawanvet.pythonanywhere.com
# Optional helper for PythonAnywhere host auto-add.
PYTHONANYWHERE_DOMAIN=bayawanvet.pythonanywhere.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://bayawanvet.pythonanywhere.com
DJANGO_USE_X_FORWARDED_HOST=True
DJANGO_SECURE_SSL_REDIRECT=True
DJANGO_SECURE_HSTS_SECONDS=0
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=False
DJANGO_SECURE_HSTS_PRELOAD=False
DJANGO_SECURE_REFERRER_POLICY=strict-origin-when-cross-origin
DJANGO_X_FRAME_OPTIONS=DENY
DJANGO_SESSION_COOKIE_SAMESITE=Lax
DJANGO_CSRF_COOKIE_SAMESITE=Lax
DJANGO_SECURE_CONTENT_TYPE_NOSNIFF=True
DJANGO_CSP_FRAME_ANCESTORS='none'

DB_ENGINE=django.db.backends.mysql
DB_NAME=your_pythonanywhere_db_name
DB_USER=your_pythonanywhere_db_user
DB_PASSWORD=your_pythonanywhere_db_password
DB_HOST=your_pythonanywhere_mysql_host
DB_PORT=3306
DB_CONN_MAX_AGE=60
DB_CONN_HEALTH_CHECKS=True
DB_CONNECT_TIMEOUT=10
DB_SQL_MODE=STRICT_TRANS_TABLES

CACHE_BACKEND=redis
# Use an external Redis service; PythonAnywhere does not host Redis itself.
REDIS_URL=redis://your-redis-host:6379/1
REDIS_CACHE_TIMEOUT=300
REDIS_CACHE_KEY_PREFIX=pet_adoption_prod
DJANGO_LOG_LEVEL=INFO
RATE_LIMIT_ENABLED=True
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_DEFAULT_REQUESTS=60
RATE_LIMIT_AUTH_REQUESTS=10
RATE_LIMIT_AUTH_IP_BURST_REQUESTS=60
RATE_LIMIT_INTERACTION_REQUESTS=30
RATE_LIMIT_SUBMISSION_REQUESTS=12

CREATE_DEFAULT_ADMIN=False
DEFAULT_ADMIN_USERNAME=
DEFAULT_ADMIN_EMAIL=
DEFAULT_ADMIN_PASSWORD=

GOOGLE_CLIENT_ID=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_GRAPH_API_VERSION=v20.0
SITE_BASE_URL=https://bayawanvet.pythonanywhere.com

EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
DEFAULT_FROM_EMAIL=no-reply@yourdomain.com
EMAIL_HOST=smtp.your-mail-provider.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_TIMEOUT=10
