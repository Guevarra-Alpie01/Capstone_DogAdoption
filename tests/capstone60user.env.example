# 60 virtual users: 0 anonymous + 50 members + 3 vet staff + 7 vet admins
# Copy to capstone60user.env (or set in shell), fill in secrets, then run tests/run_locust_60user.ps1

# --- Concurrency (fixed_count per Locust user class) ---
LOAD_TEST_PUBLIC_FIXED_COUNT=0
LOAD_TEST_USER_FIXED_COUNT=50
LOAD_TEST_STAFF_FIXED_COUNT=3
LOAD_TEST_ADMIN_FIXED_COUNT=7

# Optional: keep steady mode pinned at 60 users after ramp (3 stages, same target)
# LOAD_TEST_RAMP_USERS=60,60,60
# LOAD_TEST_RAMP_STAGE_SECONDS=120,300,600
# LOAD_TEST_RAMP_SPAWN_RATES=8,8,8

# --- Credentials (use comma-separated user:pass pairs for multiple accounts) ---
# Member accounts (at least 1; 50 VUs will rotate / reuse)
# LOAD_TEST_USER_USERNAME=
# LOAD_TEST_USER_PASSWORD=
# LOAD_TEST_USER_CREDENTIALS=member1:pass1,member2:pass2

# Vet staff (3 accounts recommended for 3 VUs)
# LOAD_TEST_STAFF_USERNAME=
# LOAD_TEST_STAFF_PASSWORD=
# LOAD_TEST_STAFF_CREDENTIALS=staff1:pass1,staff2:pass2,staff3:pass3

# Full admins (7 accounts recommended for 7 VUs)
# LOAD_TEST_ADMIN_USERNAME=
# LOAD_TEST_ADMIN_PASSWORD=
# LOAD_TEST_ADMIN_CREDENTIALS=admin1:pass1,admin2:pass2

# Base URL of the app under test (also pass to locust with --host)
# LOADTEST_HOST=http://127.0.0.1:8000
